# ============================================================
# Environment Variables — Tourism AI Assistant Platform
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ------------------------------------------------------------
# OPTION A: Google Gemini API (recommended)
# Get your key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
OPENROUTER_API_KEY=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
# ------------------------------------------------------------
# OPTION B: OpenRouter API (alternative — supports many models)
# Get your key at: https://openrouter.ai/keys
# ------------------------------------------------------------
# OPENROUTER_API_KEY='AIzaSyBrLOFl4nA_dQtUTCw2hpE9xiuZsNctnxU'
# ------------------------------------------------------------
# AI provider selection: "gemini" or "openrouter"
# ------------------------------------------------------------
AI_PROVIDER=openrouter
# ------------------------------------------------------------
# Server settings
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ------------------------------------------------------------
# CORS — set to your frontend URL in production
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
